APP_ENV=test
APP_NAME="Deploy Service"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL=DEBUG

# JWT
SECRET_KEY=test-secret-key-for-testing-only-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=5

# Users store — points to a test fixture during tests
USERS_JSON_PATH=tests/fixtures/users.json

# Whitelist + SSH config files — under tests/fixtures/ during tests
# so CI doesn't depend on data/ which contains real keys / placeholders
COMMAND_CONFIG_DIR=tests/fixtures

# Redis — e2e tests hit the real instance started by docker-compose
REDIS_URL=redis://:your_strong_password@localhost:6379/0

# GitLab — mocked during tests
GITLAB_URL=https://gitlab.com/
GITLAB_TOKEN=test-token
GITLAB_PROJECT_ID=12345

# Inventory API — tests override via dependency injection, but config must load
INVENTORY_API_URL=http://localhost:9001
INVENTORY_API_TOKEN=test-token
INVENTORY_API_TIMEOUT_SECONDS=1

# Cluster / Bastion mapping API — tests override via DI; config must still load
CLUSTER_API_URL=http://localhost:9001
CLUSTER_API_TOKEN=test-cluster-token
CLUSTER_API_TIMEOUT_SECONDS=1
BASTION_DEFAULT_TYPE=type1
