APP_ENV=prod
APP_NAME="Deploy Service"
APP_VERSION="0.1.0"
DEBUG=false
LOG_LEVEL=INFO

# JWT — override with a strong secret in production!
SECRET_KEY=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Users store
USERS_JSON_PATH=data/users.json

# GitLab
GITLAB_URL=https://gitlab.com/
GITLAB_TOKEN=REPLACE_WITH_GITLAB_TOKEN
GITLAB_PROJECT_ID=79912706


# redis 
REDIS_URL="redis://:your_strong_password@localhost:6379/0"