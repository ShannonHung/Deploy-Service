APP_ENV=dev
APP_NAME="Deploy Service"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL=DEBUG

# JWT
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Users store
USERS_JSON_PATH=data/users.json

# GitLab
GITLAB_URL=https://gitlab.com/
GITLAB_TOKEN=
GITLAB_PROJECT_ID=79912706
GITLAB_AUTH_JSON_PATH=data/gitlab_auth.json

# redis 
REDIS_URL="redis://:your_strong_password@localhost:6379/0"