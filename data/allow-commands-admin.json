{
  "name": "admin",
  "allow_hosts": [
    ".*"
  ],
  "deny_hosts": [
    "10\\.0\\..*"
  ],
  "allow_commands": [
    {
      "command_name": "reboot",
      "description": "reboot",
      "disconnects_ssh": true,
      "killable": false,
      "pipeline": [
        {
          "command": [
            "reboot"
          ]
        }
      ],
      "arguments": []
    },
    {
      "command_name": "sleep",
      "description": "sleep",
      "disconnects_ssh": false,
      "killable": true,
      "pipeline": [
        {
          "command": [
            "sleep",
            "{time}"
          ]
        }
      ],
      "arguments": [
        {
          "name": "time",
          "type": "int",
          "validation_regex": "^[0-9]+$"
        }
      ]
    },
    {
      "command_name": "list_file_all",
      "description": "list file",
      "disconnects_ssh": false,
      "killable": true,
      "pipeline": [
        {
          "command": [
            "ls",
            "-al"
          ]
        }
      ],
      "arguments": []
    },
    {
      "command_name": "list_file",
      "description": "list file",
      "disconnects_ssh": false,
      "killable": true,
      "pipeline": [
        {
          "command": [
            "ls",
            "-al"
          ]
        },
        {
          "command": [
            "grep",
            "{key_word}"
          ]
        },
        {
          "command": [
            "grep",
            "{key_word2}"
          ]
        }
      ],
      "arguments": [
        {
          "name": "key_word",
          "type": "string",
          "validation_regex": ".*"
        },
        {
          "name": "key_word2",
          "type": "string",
          "validation_regex": "^[a-zA-Z0-9._-]+$"
        }
      ]
    },
    {
      "command_name": "whoami",
      "description": "whoami",
      "disconnects_ssh": false,
      "killable": true,
      "pipeline": [
        {
          "command": [
            "whoami"
          ]
        }
      ],
      "arguments": []
    }
  ]
}